# Palmkit External Worker — Environment Variables
# Copy to .env and fill in. NEVER commit .env.

# ─── Supabase (service role — server only, NEVER expose to browser) ─────────
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── API Key Encryption (MUST match the CF Pages app's key) ─────────────────
# This is the SAME API_KEY_ENCRYPTION_KEY set on Cloudflare Pages.
# The worker uses it to decrypt user API keys stored in user_api_keys.
# Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_KEY=your-base64-32-byte-key-here

# ─── Cloudflare R2 (file storage) ───────────────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=palmkit-files

# ─── Worker config ──────────────────────────────────────────────────────────
WORKER_PORT=8787
WORKER_DEBUG=0

# ─── OPTIONAL: only needed for specific providers ───────────────────────────
# Amazon Bedrock
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_SECRET=your-aws-secret

# OpenAI-like (custom baseURL)
# OPENAI_LIKE_BASE_URL=https://your-custom-endpoint/v1

# NOTE: The worker does NOT use OPENROUTER_API_KEY or per-provider env vars.
# API keys come from each user's encrypted user_api_keys row, decrypted with
# API_KEY_ENCRYPTION_KEY. This matches Palmkit's multi-provider architecture
# where users enter their own keys via the UI.
